  <!-- سكريبت السلايدر -->
  <script>
    (function() {
      const track = document.getElementById('slider-track');
      const prevBtn = document.getElementById('hero-prev');
      const nextBtn = document.getElementById('hero-next');
      const dots = document.querySelectorAll('.dot');
      
      if (!track || !prevBtn || !nextBtn || dots.length === 0) return;

      const totalSlides = dots.length;
      let currentIndex = 0;
      let autoplayTimer: NodeJS.Timeout | null = null;
      const AUTOPLAY_INTERVAL = 4500;

      function updateSlider(index: number) {
        if (index < 0) index = totalSlides - 1;
        if (index >= totalSlides) index = 0;
        currentIndex = index;
        
        if (track) {
          track.style.transform = `translateX(${-currentIndex * 100}%)`;
        }
        
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }

      function nextSlide() { updateSlider(currentIndex + 1); }
      function prevSlide() { updateSlider(currentIndex - 1); }

      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = setInterval(nextSlide, AUTOPLAY_INTERVAL);
      }
      function stopAutoplay() {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      prevBtn.addEventListener('click', () => { prevSlide(); startAutoplay(); });
      nextBtn.addEventListener('click', () => { nextSlide(); startAutoplay(); });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { updateSlider(i); startAutoplay(); });
      });

      const sliderSection = document.querySelector('.hero-slider-section');
      if (sliderSection) {
        sliderSection.addEventListener('mouseenter', stopAutoplay);
        sliderSection.addEventListener('mouseleave', startAutoplay);
      }

      // دعم اللمس
      let touchStartX = 0;
      let touchEndX = 0;
      const viewport = document.querySelector('.slider-viewport');
      if (viewport) {
        viewport.addEventListener('touchstart', (e: Event) => {
          const touch = e as TouchEvent;
          touchStartX = touch.changedTouches[0].screenX;
          stopAutoplay();
        }, {passive: true});
        viewport.addEventListener('touchend', (e: Event) => {
          const touch = e as TouchEvent;
          touchEndX = touch.changedTouches[0].screenX;
          handleSwipe();
          startAutoplay();
        });
      }
      function handleSwipe() {
        const threshold = 50;
        if (touchEndX < touchStartX - threshold) nextSlide();
        else if (touchEndX > touchStartX + threshold) prevSlide();
      }

      startAutoplay();
    })();
  </script>

  <!-- تتبع النقرات على أزرار الشراء -->
  <script>
    declare global {
      interface Window {
        Lit?: { event: (name: string, data: any) => void };
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      const buyButtons = document.querySelectorAll('.btn-buy-hero, .btn-buy-mini');
      buyButtons.forEach(btn => {
        btn.addEventListener('click', function(this: HTMLElement) {
          if (typeof window.Lit !== 'undefined') {
            window.Lit.event('click_on_buy', {
              metadata: {
                'product': this.getAttribute('data-product') || 'unknown',
                'page': window.location.pathname
              }
            });
          }
        });
      });

      const ratingStorageKey = 'bikilika_rating_data';
      const ratingSummary = document.getElementById('rating-summary');
      const ratingStars = document.querySelectorAll<HTMLButtonElement>('#rating-stars button');
      const ratingThanks = document.getElementById('rating-thanks');

      function getRatingData() {
        const stored = window.localStorage.getItem(ratingStorageKey);
        return stored ? JSON.parse(stored) : { total: 0, count: 0 };
      }

      function saveRatingData(data: { total: number; count: number }) {
        window.localStorage.setItem(ratingStorageKey, JSON.stringify(data));
      }

      function updateRatingDisplay(data: { total: number; count: number }) {
        const average = data.count ? (data.total / data.count).toFixed(1) : '0.0';
        if (ratingSummary) {
          ratingSummary.textContent = `${average} من 5 (${data.count} تقييم)`;
        }
        ratingStars.forEach((btn) => {
          const value = Number(btn.dataset.value);
          btn.classList.toggle('selected', data.count > 0 && value <= Math.round(data.total / data.count));
        });
      }

      const ratingData = getRatingData();
      updateRatingDisplay(ratingData);

      ratingStars.forEach((btn) => {
        btn.addEventListener('click', function(this: HTMLButtonElement) {
          const value = Number(this.dataset.value);
          const newData = { total: ratingData.total + value, count: ratingData.count + 1 };
          saveRatingData(newData);
          updateRatingDisplay(newData);
          if (ratingThanks) {
            ratingThanks.textContent = 'شكراً لك! تم تسجيل تقييمك.';
          }
        });
      });
    });
  </script>
</body>
