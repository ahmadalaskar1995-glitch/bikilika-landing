---
import { getSiteConfig, getPageBySlug } from '../../lib/content.js';
import { renderMarkdown } from '../../lib/markdown.js';

export const prerender = false;

const runtimeEnv = Astro.locals.runtime?.env;
const config = await getSiteConfig(runtimeEnv);
const { slug } = Astro.params;
if (!slug) throw new Error('Missing page slug');
const pageEntry = await getPageBySlug(slug, runtimeEnv);
if (!pageEntry) throw new Error(`Page not found: ${slug}`);

const pageData = pageEntry.data;
const pageContent = pageEntry.body || '';
const pageHtml = await renderMarkdown(pageContent, {
  siteTitle: config.siteTitle,
  email: config.email,
  whatsapp: config.whatsapp,
});
---

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageData.title} | {config.siteTitle}</title>
  <meta name="description" content={pageData.description || config.description}>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', 'Cairo', sans-serif; background: #f9fafb; color: #1f2937; line-height: 1.7; }
    .container { max-width: 1000px; margin: 0 auto; padding: 20px; }
    .site-header {
      background: linear-gradient(135deg, #f97316 0%, #ec4899 100%);
      border-radius: 0 0 40px 40px;
      padding: 25px 35px;
      margin-bottom: 40px;
      box-shadow: 0 15px 30px -8px rgba(249, 115, 22, 0.25);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 20px;
      color: white;
    }
    .logo-area { display: flex; align-items: center; gap: 20px; }
    .logo-img { height: 70px; width: auto; object-fit: contain; filter: drop-shadow(0 6px 8px rgba(0,0,0,0.15)); }
    .site-title { font-size: 2.5rem; font-weight: 800; color: white; text-shadow: 0 2px 5px rgba(0,0,0,0.15); }
    .site-description { color: rgba(255,255,255,0.95); font-size: 1.2rem; max-width: 420px; background: rgba(0,0,0,0.18); padding: 10px 20px; border-radius: 50px; backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.18); }
    .contact-float { position: fixed; left: 30px; bottom: 30px; display: flex; flex-direction: column; gap: 12px; z-index: 1000; }
    .contact-button { display: inline-flex; align-items: center; gap: 10px; padding: 14px 20px; border-radius: 999px; font-size: 0.95rem; font-weight: 700; color: white; text-decoration: none; box-shadow: 0 14px 28px rgba(0,0,0,0.16); transition: transform 0.2s ease, box-shadow 0.2s ease; border: 1px solid rgba(255,255,255,0.22); backdrop-filter: blur(10px); }
    .contact-button:hover { transform: translateY(-3px); box-shadow: 0 20px 32px rgba(0,0,0,0.22); }
    .contact-button svg { width: 22px; height: 22px; }
    .contact-button.whatsapp { background: #25D366; }
    .contact-button.email { background: #D14836; }
    .contact-button span { white-space: nowrap; }
    @media (max-width: 700px) {
      .site-header { flex-direction: column; align-items: flex-start; }
      .site-title { font-size: 2rem; }
      .contact-float { left: 16px; bottom: 16px; }
    }
    .back-link { display: inline-block; margin-bottom: 20px; color: #f97316; text-decoration: none; font-weight: bold; font-size: 1.1rem; }
    .back-link:hover { text-decoration: underline; }
    .page-content {
      background: white;
      border-radius: 24px;
      padding: 40px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
      margin-bottom: 40px;
    }
    .page-content h1 { font-size: 2.5rem; margin-bottom: 30px; color: #1e293b; border-bottom: 2px solid #f97316; padding-bottom: 15px; }
    .page-content h2 { font-size: 1.8rem; margin: 30px 0 15px; color: #334155; }
    .page-content p { margin-bottom: 20px; }
    footer { margin-top: 60px; text-align: center; padding: 30px 0; color: #6b7280; border-top: 1px solid #e5e7eb; }
  </style>
</head>
<body>
  <div class="container">
    <header class="site-header">
      <div class="logo-area">
        {config.logo ? (
          <img src={config.logo} alt={config.siteTitle} class="logo-img" />
        ) : (
          <div style="width:70px;height:70px;background:rgba(255,255,255,0.2);border-radius:20px;display:flex;align-items:center;justify-content:center;color:white;font-size:32px;backdrop-filter:blur(6px);">✨</div>
        )}
        <h1 class="site-title">{config.siteTitle}</h1>
      </div>
      {config.description && <div class="site-description">{config.description}</div>}
    </header>
    <main>
      <a href="/" class="back-link">← العودة للرئيسية</a>
      <article class="page-content">
        <h1>{pageData.title}</h1>
        {pageHtml && <div set:html={pageHtml} />}
      </article>
    </main>
    <footer>
      <p>© {new Date().getFullYear()} {config.siteTitle}. جميع الحقوق محفوظة.</p>
    </footer>
  </div>

  {(config.whatsapp || config.email) && (
    <div class="contact-float">
      {config.whatsapp && (
        <a href={`https://wa.me/${config.whatsapp}`} class="contact-button whatsapp" target="_blank" rel="noopener" aria-label="تواصل معنا عبر واتساب">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M12 0C5.373 0 0 5.373 0 12c0 2.165.582 4.2 1.593 5.947L.22 23.78l6.053-1.587A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22.5c-1.943 0-3.764-.522-5.333-1.426l-3.715.974.99-3.618A10.45 10.45 0 0 1 1.5 12C1.5 6.21 6.21 1.5 12 1.5S22.5 6.21 22.5 12 17.79 22.5 12 22.5z"/><path d="M17.5 14.5c-.3 0-.6-.1-.8-.3l-2.5-1.7c-.5-.3-.6-.9-.3-1.4l.2-.3c.1-.1.2-.2.3-.3.1-.1.2-.1.3-.1h.2c.2 0 .4.1.6.2l2.5 1.7c.5.3.6.9.3 1.4l-.1.1c-.3.4-.5.7-.7.7z"/><path d="M6.5 14.5c-.2 0-.4-.1-.5-.2l-.2-.2c-.3-.5-.3-1.1 0-1.6l.2-.2c.1-.1.2-.2.3-.3l.3-.2c.1 0 .2-.1.3-.1.2 0 .4.1.6.2l2.5 1.7c.5.3.6.9.3 1.4l-.1.1c-.2.4-.5.6-.7.7-.2 0-.4.1-.6 0z"/></svg>
          <span>WhatsApp</span>
        </a>
      )}
      {config.email && (
        <a href={`mailto:${config.email}`} class="contact-button email" aria-label="إرسال بريد إلكتروني">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4.99l-8 4.99-8-4.99V6l8 4.99L20 6v2.99z"/></svg>
          <span>Gmail</span>
        </a>
      )}
    </div>
  )}
</body>
</html>
