---
export const prerender = false;

import { getSiteConfig, getProductBySlug } from '../../lib/content.js';

const { slug } = Astro.params;
const productEntry = await getProductBySlug(slug);
if (!productEntry) {
  throw Astro.redirect('/404');
}

const product = productEntry.data;
const config = await getSiteConfig();
const siteConfig = config;

// تجهيز مصفوفة الصور
const images = product.images?.length ? product.images : (product.image ? [product.image] : []);

// بناء كود JSON-LD للمنتج (SEO)
const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.title,
  "description": product.description,
  "image": images.length > 0 ? images[0] : undefined,
  "offers": {
    "@type": "Offer",
    "price": product.price.replace(/[^0-9.]/g, ''),
    "priceCurrency": "SAR",
    "availability": "https://schema.org/InStock",
    "url": product.bikilikaLink
  }
};
---

<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{product?.title || 'منتج'} | {siteConfig.siteTitle}</title>
  <meta name="description" content={product?.description || siteConfig.description}>
  
  <!-- Litlyx Analytics -->
  <script defer data-workspace="YOUR_WORKSPACE_ID" src="https://cdn.jsdelivr.net/npm/litlyx-js@latest/browser/litlyx.js"></script>
  
  <!-- SEO Schema -->
  <script type="application/ld+json">
    {JSON.stringify(productSchema)}
  </script>

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', 'Cairo', sans-serif; background: #f9fafb; color: #1f2937; line-height: 1.6; }
    .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
    
    /* الهيدر */
    .site-header {
      background: linear-gradient(135deg, #f97316 0%, #ec4899 100%);
      border-radius: 0 0 40px 40px;
      padding: 20px 30px;
      margin-bottom: 30px;
      box-shadow: 0 15px 30px -8px rgba(249, 115, 22, 0.25);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 20px;
      color: white;
    }
    .logo-area { display: flex; align-items: center; gap: 20px; }
    .logo-img { height: 60px; width: auto; object-fit: contain; filter: drop-shadow(0 6px 8px rgba(0,0,0,0.15)); }
    .site-title { font-size: 2.2rem; font-weight: 800; color: white; text-shadow: 0 2px 5px rgba(0,0,0,0.15); }
    .site-description { color: rgba(255,255,255,0.95); font-size: 1.1rem; max-width: 420px; background: rgba(0,0,0,0.18); padding: 10px 20px; border-radius: 50px; backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.2); }
    .contact-float { position: fixed; left: 30px; bottom: 30px; display: flex; flex-direction: column; gap: 12px; z-index: 1000; }
    .contact-button { display: inline-flex; align-items: center; gap: 10px; padding: 14px 20px; border-radius: 999px; font-size: 0.95rem; font-weight: 700; color: white; text-decoration: none; box-shadow: 0 14px 28px rgba(0,0,0,0.16); transition: transform 0.2s ease, box-shadow 0.2s ease; border: 1px solid rgba(255,255,255,0.22); backdrop-filter: blur(10px); }
    .contact-button:hover { transform: translateY(-3px); box-shadow: 0 20px 32px rgba(0,0,0,0.22); }
    .contact-button svg { width: 22px; height: 22px; }
    .contact-button.whatsapp { background: #25D366; }
    .contact-button.email { background: #D14836; }
    .contact-button span { white-space: nowrap; }
    @media (max-width: 700px) {
      .site-header { flex-direction: column; align-items: flex-start; }
      .site-title { font-size: 1.8rem; }
      .contact-float { left: 16px; bottom: 16px; }
    }

    /* زر العودة */
    .back-link { display: inline-block; margin-bottom: 20px; color: #f97316; text-decoration: none; font-weight: bold; font-size: 1.1rem; }
    .back-link:hover { text-decoration: underline; }

    /* بطاقة المنتج */
    .product-detail { background: white; border-radius: 32px; padding: 30px; box-shadow: 0 20px 35px -8px rgba(0,0,0,0.1); }

    /* سلايدر الصور */
    .slider-container { position: relative; width: 100%; margin-bottom: 30px; border-radius: 24px; overflow: hidden; }
    .slider-wrapper { display: flex; transition: transform 0.5s ease; direction: ltr; }
    .slider-slide { flex: 0 0 100%; min-width: 100%; }
    .slider-image { width: 100%; height: 450px; object-fit: contain; background: #fef2f2; border-radius: 24px; }
    .slider-btn {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: white; border: none; width: 50px; height: 50px; border-radius: 50%;
      font-size: 28px; display: flex; align-items: center; justify-content: center;
      cursor: pointer; box-shadow: 0 8px 20px rgba(0,0,0,0.12); transition: all 0.2s;
      color: #f97316; z-index: 10;
    }
    .slider-btn:hover { background: #f97316; color: white; transform: scale(1.07); }
    .slider-btn.prev { left: 20px; }
    .slider-btn.next { right: 20px; }
    .slider-dots { display: flex; justify-content: center; gap: 12px; margin-top: 20px; }
    .dot { width: 12px; height: 12px; border-radius: 50%; background: #d1d5db; cursor: pointer; transition: all 0.2s; }
    .dot.active { background: #f97316; width: 30px; border-radius: 20px; }

    .product-title { font-size: 2.5rem; font-weight: 800; color: #111827; margin: 20px 0 10px; }
    .product-price { font-size: 2.2rem; font-weight: 700; color: #059669; margin: 15px 0; display: inline-block; background: #ecfdf5; padding: 6px 24px; border-radius: 40px; }
    .product-description { font-size: 1.2rem; color: #4b5563; line-height: 1.8; margin: 20px 0; }
    .buy-button {
      display: inline-block; background: linear-gradient(145deg, #f97316, #ea580c);
      color: white; text-decoration: none; padding: 16px 36px; border-radius: 60px;
      font-weight: 700; font-size: 1.2rem; box-shadow: 0 12px 24px -8px rgba(249,115,22,0.4);
      transition: all 0.2s; margin-top: 20px;
    }
    .buy-button:hover { background: linear-gradient(145deg, #ea580c, #c2410c); transform: translateY(-3px); }

    .no-images-placeholder {
      width: 100%; height: 300px; background: #f3f4f6; border-radius: 24px;
      display: flex; align-items: center; justify-content: center; color: #9ca3af; font-size: 1.2rem;
    }

    /* فوتر */
    footer { margin-top: 60px; text-align: center; padding: 30px 0; color: #6b7280; border-top: 1px solid #e5e7eb; }

    .contact-float { position: fixed; left: 30px; bottom: 30px; display: flex; flex-direction: column; gap: 12px; z-index: 1000; }
    .contact-button { display: inline-flex; align-items: center; gap: 10px; padding: 14px 20px; border-radius: 999px; font-size: 0.95rem; font-weight: 700; color: white; text-decoration: none; box-shadow: 0 14px 28px rgba(0,0,0,0.16); transition: transform 0.2s ease, box-shadow 0.2s ease; border: 1px solid rgba(255,255,255,0.22); backdrop-filter: blur(10px); }
    .contact-button:hover { transform: translateY(-3px); box-shadow: 0 20px 32px rgba(0,0,0,0.22); }
    .contact-button svg { width: 22px; height: 22px; }
    .contact-button.whatsapp { background: #25D366; }
    .contact-button.email { background: #D14836; }
    .contact-button span { white-space: nowrap; }
    @media (max-width: 768px) {
      .contact-float { left: 20px; bottom: 20px; }
      .contact-button { padding: 12px 18px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="site-header">
      <div class="logo-area">
        {siteConfig.logo ? (
          <img src={siteConfig.logo} alt={siteConfig.siteTitle} class="logo-img" />
        ) : (
          <div style="width:60px;height:60px;background:rgba(255,255,255,0.2);border-radius:20px;display:flex;align-items:center;justify-content:center;color:white;font-size:28px;backdrop-filter:blur(6px);">✨</div>
        )}
        <h1 class="site-title">{siteConfig.siteTitle}</h1>
      </div>
      {siteConfig.description && <div class="site-description">{siteConfig.description}</div>}
    </header>

    <main>
      <a href="/" class="back-link">← العودة للمتجر</a>
      
      {product ? (
        <div class="product-detail">
          {images.length > 0 ? (
            <div class="slider-container" id="product-slider">
              <div class="slider-wrapper" id="slider-wrapper">
                {images.map((img: string, index: number) => (
                  <div class="slider-slide">
                    <img src={img} alt={`${product.title} - صورة ${index+1}`} class="slider-image" />
                  </div>
                ))}
              </div>
              {images.length > 1 && (
                <>
                  <button class="slider-btn prev" id="prevBtn">❮</button>
                  <button class="slider-btn next" id="nextBtn">❯</button>
                  <div class="slider-dots" id="slider-dots">
                    {images.map((_: string, idx: number) => (
                      <span class={`dot ${idx === 0 ? 'active' : ''}`} data-index={idx}></span>
                    ))}
                  </div>
                </>
              )}
            </div>
          ) : (
            <div class="no-images-placeholder">🖼️ لا توجد صور للمنتج</div>
          )}

          <h2 class="product-title">{product.title}</h2>
          <div class="product-price">{product.price}</div>
          <div class="product-description">{product.description || ''}</div>
          <a href={product.bikilikaLink} class="buy-button" target="_blank" rel="noopener" data-product={product.title}>
            🛒 اشتر الآن
          </a>
        </div>
      ) : (
        <p>عذراً، المنتج غير موجود.</p>
      )}
    </main>

    <footer>
      <p>© {new Date().getFullYear()} {siteConfig.siteTitle}. جميع الحقوق محفوظة.</p>
    </footer>
  </div>

  <!-- أزرار التواصل العائمة -->
  {(siteConfig.whatsapp || siteConfig.email) && (
    <div class="contact-float">
      {siteConfig.whatsapp && (
        <a href={`https://wa.me/${siteConfig.whatsapp}`} class="contact-button whatsapp" target="_blank" rel="noopener" aria-label="تواصل معنا عبر واتساب">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M12 0C5.373 0 0 5.373 0 12c0 2.165.582 4.2 1.593 5.947L.22 23.78l6.053-1.587A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22.5c-1.943 0-3.764-.522-5.333-1.426l-3.715.974.99-3.618A10.45 10.45 0 0 1 1.5 12C1.5 6.21 6.21 1.5 12 1.5S22.5 6.21 22.5 12 17.79 22.5 12 22.5z"/><path d="M17.5 14.5c-.3 0-.6-.1-.8-.3l-2.5-1.7c-.5-.3-.6-.9-.3-1.4l.2-.3c.1-.1.2-.2.3-.3.1-.1.2-.1.3-.1h.2c.2 0 .4.1.6.2l2.5 1.7c.5.3.6.9.3 1.4l-.1.1c-.3.4-.5.7-.7.7z"/><path d="M6.5 14.5c-.2 0-.4-.1-.5-.2l-.2-.2c-.3-.5-.3-1.1 0-1.6l.2-.2c.1-.1.2-.2.3-.3l.3-.2c.1 0 .2-.1.3-.1.2 0 .4.1.6.2l2.5 1.7c.5.3.6.9.3 1.4l-.1.1c-.2.4-.5.6-.7.7-.2 0-.4.1-.6 0z"/></svg>
          <span>WhatsApp</span>
        </a>
      )}
      {siteConfig.email && (
        <a href={`mailto:${siteConfig.email}`} class="contact-button email" aria-label="إرسال بريد إلكتروني">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4.99l-8 4.99-8-4.99V6l8 4.99L20 6v2.99z"/></svg>
          <span>Gmail</span>
        </a>
      )}
    </div>
  )}

  <!-- سكريبت السلايدر -->
  <script>
    (function() {
      const wrapper = document.getElementById('slider-wrapper') as HTMLElement | null;
      const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement | null;
      const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement | null;
      const dots = document.querySelectorAll('.dot');
      
      if (!wrapper || !prevBtn || !nextBtn || dots.length === 0) return;

      let currentIndex = 0;
      const totalSlides = dots.length;
      let autoplayTimer: ReturnType<typeof setInterval> | null = null;
      const AUTOPLAY_DELAY = 4000;

      function updateSlider(index: number) {
        if (index < 0) index = 0;
        if (index >= totalSlides) index = totalSlides - 1;
        currentIndex = index;
        (wrapper as HTMLElement).style.transform = `translateX(${-currentIndex * 100}%)`;
        dots.forEach((dot, i) => dot.classList.toggle('active', i === currentIndex));
      }

      function nextSlide() { updateSlider(currentIndex + 1); }
      function prevSlide() { updateSlider(currentIndex - 1); }

      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = setInterval(nextSlide, AUTOPLAY_DELAY);
      }
      function stopAutoplay() {
        if (autoplayTimer) clearInterval(autoplayTimer);
        autoplayTimer = null;
      }

      prevBtn.addEventListener('click', () => { prevSlide(); startAutoplay(); });
      nextBtn.addEventListener('click', () => { nextSlide(); startAutoplay(); });
      dots.forEach((dot, i) => dot.addEventListener('click', () => { updateSlider(i); startAutoplay(); }));

      const slider = document.getElementById('product-slider');
      if (slider) {
        slider.addEventListener('mouseenter', stopAutoplay);
        slider.addEventListener('mouseleave', startAutoplay);

        // دعم اللمس
        let touchStartX = 0, touchEndX = 0;
        slider.addEventListener('touchstart', (e) => { touchStartX = e.changedTouches[0].screenX; stopAutoplay(); }, {passive: true});
        slider.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          const threshold = 50;
          if (touchEndX < touchStartX - threshold) nextSlide();
          else if (touchEndX > touchStartX + threshold) prevSlide();
          startAutoplay();
        });
      }

      startAutoplay();
    })();
  </script>

  <!-- تتبع النقرات -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const buyBtn = document.querySelector('.buy-button');
      if (buyBtn) {
        buyBtn.addEventListener('click', function(this: HTMLElement) {
          if (typeof (window as any).Lit !== 'undefined') {
            (window as any).Lit.event('click_on_buy', {
              metadata: {
                'product': this.getAttribute('data-product') || 'unknown',
                'page': window.location.pathname
              }
            });
          }
        });
      }
    });
  </script>
</body>
</html>